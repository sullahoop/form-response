{
  "name": "garu-ko",
  "version": "0.9.4",
  "description": "Ultra-lightweight Korean morphological analyzer for the web (1MB model, WASM, F1 93.7% NIKL MP)",
  "type": "module",
  "main": "dist/node.js",
  "browser": "dist/browser.js",
  "types": "dist/node.d.ts",
  "exports": {
    ".": {
      "types": "./dist/node.d.ts",
      "browser": "./dist/browser.js",
      "node": "./dist/node.js",
      "default": "./dist/node.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "default": "./dist/browser.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "default": "./dist/node.js"
    }
  },
  "files": [
    "dist",
    "pkg",
    "models",
    "README.md"
  ],
  "scripts": {
    "build:wasm": "wasm-pack build ../crates/garu-wasm --target web --out-dir ../../js/pkg && rm -f pkg/.gitignore",
    "build:js": "tsc",
    "build": "npm run build:wasm && npm run build:js",
    "prepublishOnly": "rm -f pkg/.gitignore",
    "test": "vitest run"
  },
  "keywords": [
    "korean",
    "morphological-analysis",
    "korean-nlp",
    "pos-tagging",
    "tokenizer",
    "nlp",
    "wasm",
    "webassembly",
    "lightweight",
    "browser",
    "offline",
    "한국어",
    "형태소-분석",
    "형태소-분석기"
  ],
  "homepage": "https://garu.zerry.co.kr",
  "bugs": {
    "url": "https://github.com/ongjin/garu/issues"
  },
  "author": "cyj <dydwls140@naver.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ongjin/garu.git"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.4",
    "vitest": "^2.0"
  }
}
